{
      "headers": [
          {
                "source": "/(.*)",
                      "headers": [
                              {
                                        "key": "Content-Security-Policy",
                                                  "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.anthropic.com"
                                                          },
                                                                  {
                                                                            "key": "X-Frame-Options",
                                                                                      "value": "DENY"
                                                                                              },
                                                                                                      {
                                                                                                                "key": "X-Content-Type-Options",
                                                                                                                          "value": "nosniff"
                                                                                                                                  }
                                                                                                                                        ]
                                                                                                                                            }
                                                                                                                                              ],
                                                                                                                                                "rewrites": [
                                                                                                                                                    {
                                                                                                                                                          "source": "/api/(.*)",
                                                                                                                                                                "destination": "/api/$1"
                                                                                                                                                                    }
                                                                                                                                                                      ]
                                                                                                                                                                      }
}